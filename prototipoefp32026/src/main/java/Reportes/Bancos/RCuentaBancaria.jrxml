<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RCuentaBancaria"
              language="groovy"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20"
              uuid="5d29b3a1-5a02-464b-b0fb-b36f19e55835">

    <queryString language="SQL">
        <![CDATA[SELECT * FROM `cuentabancaria` ORDER BY Banid]]>
    </queryString>

    <field name="CBANid" class="java.lang.Integer"/>
    <field name="CBANnumerocuenta" class="java.lang.String"/>
    <field name="CBANsaldoactual" class="java.math.BigDecimal"/>
    <field name="CBANfechaapertura" class="java.sql.Date"/>
    <field name="Banid" class="java.lang.Integer"/>
    <field name="Cliid" class="java.lang.Integer"/>
    <field name="TCidcuenta" class="java.lang.Integer"/>

    <group name="Banid">
        <groupExpression><![CDATA[$F{Banid}]]></groupExpression>
        <groupHeader>
            <band height="25" splitType="Stretch">
                <rectangle>
                    <reportElement x="0" y="0" width="802" height="22" backcolor="#D6EAF8" forecolor="#D6EAF8"/>
                    <graphicElement fill="Solid">
                        <pen lineWidth="0.0"/>
                    </graphicElement>
                </rectangle>
                <staticText>
                    <reportElement x="0" y="3" width="100" height="16" forecolor="#1A5276"/>
                    <textElement verticalAlignment="Middle">
                        <font size="8" isBold="true"/>
                    </textElement>
                    <text><![CDATA[Banco ID:]]></text>
                </staticText>
                <textField>
                    <reportElement x="100" y="3" width="100" height="16" forecolor="#1A5276"/>
                    <textElement verticalAlignment="Middle">
                        <font size="8" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{Banid}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <background>
        <band splitType="Stretch"/>
    </background>

    <!-- TÍTULO -->
    <title>
        <band height="70" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="60" backcolor="#1A5276" forecolor="#1A5276"/>
                <graphicElement fill="Solid">
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="10" width="802" height="40" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[REPORTE DE CUENTAS BANCARIAS]]></text>
            </staticText>
        </band>
    </title>

    <!-- ENCABEZADO DE PÁGINA -->
    <pageHeader>
        <band height="20" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="0" width="802" height="20" forecolor="#666666"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Sistema Bancario]]></text>
            </staticText>
        </band>
    </pageHeader>

    <!-- ENCABEZADO DE COLUMNAS -->
    <columnHeader>
        <band height="30" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="30" backcolor="#2E86C1" forecolor="#2E86C1"/>
                <graphicElement fill="Solid">
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="50" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="50" y="0" width="160" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[NÚMERO DE CUENTA]]></text>
            </staticText>
            <staticText>
                <reportElement x="210" y="0" width="110" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[SALDO ACTUAL]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="0" width="120" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[FECHA APERTURA]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="80" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[ID BANCO]]></text>
            </staticText>
            <staticText>
                <reportElement x="520" y="0" width="80" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[ID CLIENTE]]></text>
            </staticText>
            <staticText>
                <reportElement x="600" y="0" width="202" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[ID TIPO CUENTA]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- DETALLE -->
    <detail>
        <band height="25" splitType="Stretch">
            <line>
                <reportElement x="0" y="24" width="802" height="1" forecolor="#CCCCCC"/>
            </line>
            <textField>
                <reportElement x="0" y="0" width="50" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANid}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="50" y="0" width="160" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANnumerocuenta}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="210" y="0" width="110" height="25"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANsaldoactual}]]></textFieldExpression>
            </textField>
            <textField pattern="yyyy-MM-dd">
                <reportElement x="320" y="0" width="120" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{CBANfechaapertura}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="80" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{Banid}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="520" y="0" width="80" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{Cliid}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="600" y="0" width="202" height="25"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{TCidcuenta}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <columnFooter>
        <band height="10" splitType="Stretch"/>
    </columnFooter>

    <!-- PIE DE PÁGINA -->
    <pageFooter>
        <band height="30" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#2E86C1"/>
            </line>
            <textField>
                <reportElement x="0" y="5" width="802" height="20" forecolor="#666666"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER} + " de " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- RESUMEN -->
    <summary>
        <band height="40" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#2E86C1"/>
            </line>
            <staticText>
                <reportElement x="0" y="8" width="210" height="20" forecolor="#1A5276"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL CUENTAS:]]></text>
            </staticText>
            <textField>
                <reportElement x="210" y="8" width="110" height="20" forecolor="#1A5276"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>